{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "python-http",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server"],
      "port": 8000,
      "autoPort": true
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "."],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "npx-http-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "-c-1", "."],
      "port": 8080,
      "autoPort": true
    }
  ]
}
